{
  "name": "@confirmkit/vanilla",
  "version": "1.0.0",
  "description": "Vanilla JS adapter for ConfirmKit",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "confirm",
    "dialog",
    "vanilla",
    "js",
    "confirmkit"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@confirmkit/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "sideEffects": false
}